# Neo4j Azure Deployment Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.sample .env

# =============================================================================
# Required Configuration
# =============================================================================

# Neo4j admin password (12-72 characters, must meet Azure complexity requirements)
# If not set, a random password will be generated during deployment
NEO4J_ADMIN_PASSWORD=

# =============================================================================
# Optional Configuration
# =============================================================================

# Azure region for deployment (default: eastus)
AZURE_LOCATION=eastus

# Number of nodes: 1 for standalone, 3-10 for cluster (default: 1)
NEO4J_NODE_COUNT=1

# Azure VM size (default: Standard_E4s_v5)
NEO4J_VM_SIZE=Standard_E4s_v5

# Data disk size in GB (default: 32)
NEO4J_DISK_SIZE=32

# Neo4j version: 5 (default: 5)
NEO4J_VERSION=5

# License type: Enterprise or Evaluation (default: Evaluation)
NEO4J_LICENSE_TYPE=Evaluation

# =============================================================================
# Deployment Tool Configuration (for deployments/ directory)
# =============================================================================

# Resource group prefix for deployment tool (default: neo4j-test)
NEO4J_RESOURCE_GROUP_PREFIX=neo4j-test

# Owner email for resource tagging (auto-detected from git config if not set)
NEO4J_OWNER_EMAIL=
